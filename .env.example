# Copy this to .env.local and fill in your values

# Backend API URL (leave blank to use React proxy in development)
REACT_APP_API_URL=

# For production (your Fly.io backend URL)
# REACT_APP_API_URL=https://supper-club-api.fly.dev/api

# Stripe publishable key (for future Stripe Elements integration)
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
